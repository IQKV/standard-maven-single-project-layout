{
  "name": "@iqkv/servicename",
  "version": "0.0.0",
  "private": true,
  "description": "Provide an optional Git commit hooks.",
  "license": "Apache-2.0",
  "author": "Dima Denisenko",
  "scripts": {
    "lint": "npm run lint:stylelint",
    "lint:stylelint": "stylelint \"**/*.css\" --cache",
    "node_modules:clear": "rm -rf node_modules",
    "prepare": "husky",
    "prettier:check": "prettier . --check",
    "prettier:write": "prettier . --write",
    "release": "release-it --ci"
  },
  "lint-staged": {
    "**/*.{js}": [
      "npm run lint",
      "prettier . --check --ignore-unknown"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@semantic-release/git": "^10.0.1",
    "cz-conventional-changelog": "^3.3.0",
    "glob": "^11.0.3",
    "husky": "9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "3.5.3",
    "prettier-plugin-java": "2.6.8",
    "prettier-plugin-packagejson": "2.5.15",
    "release-it": "^19.0.2",
    "semantic-release": "^24.2.3",
    "sort-package-json": "^3.1.0",
    "stylelint": "^16.21.0",
    "stylelint-config-standard-scss": "^15.0.0"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "release-it": {
    "npm": {
      "publish": false
    },
    "git": {
      "commit": true,
      "tag": true,
      "push": true,
      "commitMessage": "feat: bump v${version}",
      "changelog": "npx auto-changelog --stdout --commit-limit false -u --template https://raw.githubusercontent.com/release-it/release-it/main/templates/changelog-compact.hbs"
    },
    "hooks": {
      "after:bump": "npx auto-changelog -p"
    }
  }
}
